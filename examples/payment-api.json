{
  "openapi": "3.0.0",
  "info": { "title": "Payment Gateway API", "version": "3.0.0" },
  "servers": [{ "url": "https://api.payments.com/v3" }],
  "paths": {
    "/transactions": {
      "get": { "summary": "List transactions", "operationId": "getTransactions", "parameters": [{"name": "status", "in": "query", "schema": {"type": "string"}}, {"name": "from_date", "in": "query", "schema": {"type": "string"}}], "responses": {"200": {"description": "Transactions list"}} },
      "post": { "summary": "Create transaction", "operationId": "createTransaction", "responses": {"201": {"description": "Transaction created"}, "402": {"description": "Payment required"}} }
    },
    "/transactions/{id}/refund": {
      "post": { "summary": "Refund transaction", "operationId": "refundTransaction", "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Refund processed"}, "400": {"description": "Refund failed"}} }
    },
    "/cards": {
      "get": { "summary": "Get saved cards", "operationId": "getCards", "responses": {"200": {"description": "Cards list"}} },
      "post": { "summary": "Add new card", "operationId": "addCard", "responses": {"201": {"description": "Card added"}} }
    },
    "/webhooks": {
      "post": { "summary": "Register webhook", "operationId": "registerWebhook", "responses": {"201": {"description": "Webhook registered"}} }
    }
  }
}
