{
  "name": "sdkcraft",
  "version": "1.0.0",
  "description": "Generate production-ready SDKs from OpenAPI specs in TypeScript, Python, Dart, Go, and Java",
  "main": "dist/cli.js",
  "bin": {
    "sdkcraft": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node cli.ts"
  },
  "keywords": [
    "openapi",
